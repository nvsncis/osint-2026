# ─── OSINT 2026 — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your credentials
# NEVER commit .env to GitHub

# ── Telegram (https://my.telegram.org) ───────────────────────────────────────
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here

# ── HaveIBeenPwned (https://haveibeenpwned.com/API/Key) ──────────────────────
HIBP_API_KEY=your_hibp_key_here

# ── DeHashed (https://dehashed.com) ──────────────────────────────────────────
DEHASHED_EMAIL=your_email_here
DEHASHED_API_KEY=your_dehashed_key_here

# ── Shodan (https://account.shodan.io) ───────────────────────────────────────
SHODAN_API_KEY=your_shodan_key_here

# ── WiGLE (https://wigle.net/account) ────────────────────────────────────────
WIGLE_USER=your_wigle_username
WIGLE_TOKEN=your_wigle_api_token

# ── Google / YouTube Data API v3 ─────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
